{
  "name": "@logpose-dev/logpose",
  "version": "0.2.0",
  "description": "Verifiable reputation and attestation SDK for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/demo.ts"
  },
  "keywords": [
    "attestation",
    "credentials",
    "did",
    "verifiable-credentials",
    "ai-agents"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "canonicalize": "^2.1.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.5.2",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
